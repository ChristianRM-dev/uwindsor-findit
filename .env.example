DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,testserver
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
DJANGO_SERVE_MEDIA_LOCALLY=true

# Local Docker/Postgres example
DATABASE_URL=postgresql://findit:findit@localhost:5432/findit

# Email defaults for local development
# Leave EMAIL_PROVIDER empty to use Django's console backend locally.
# For HTTP API testing with Brevo, set EMAIL_PROVIDER=brevo and use your verified sender:
# BREVO_API_KEY=
# DJANGO_DEFAULT_FROM_EMAIL=FindIt UWindsor <sender@example.com>
EMAIL_PROVIDER=
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_REQUEST_TIMEOUT=10

# Optional fallback if you switch EMAIL_PROVIDER=resend.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
RESEND_REQUEST_TIMEOUT=10
DJANGO_DEFAULT_FROM_EMAIL=no-reply@findit.local

REQUIRE_EMAIL_VERIFICATION=true
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCKOUT_SECONDS=900
DJANGO_SESSION_COOKIE_AGE=3600
